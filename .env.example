# =============================================================================
# OCR API — Environment Configuration
# Copy this file to .env and edit as needed.
# All values can also be passed as Docker -e flags or docker-compose env_file.
# =============================================================================

# ── OCR Engine ──────────────────────────────────────────────────────────────
# paddle    → PaddleOCR primary (best accuracy for Indian docs, x86 Linux)
#             Automatically falls back to Tesseract if PaddleOCR init fails.
# tesseract → Tesseract only (faster on ARM Mac, good for local dev)
OCR_ENGINE=paddle

# ── PaddleOCR language model ─────────────────────────────────────────────────
# devanagari → Hindi + Marathi + English + digits  ← USE THIS for Indian docs
# en         → English only (smaller/faster model, loses Hindi/Marathi)
OCR_LANG=devanagari

# ── Tesseract language packs ─────────────────────────────────────────────────
# Used when OCR_ENGINE=tesseract OR as automatic fallback.
# Requires packages: tesseract-ocr-eng  tesseract-ocr-hin  tesseract-ocr-mar
TESS_LANG=eng+hin+mar

# ── Preprocessing ────────────────────────────────────────────────────────────
# OCR_PREPROCESS=1      → run preprocessing pipeline before OCR (recommended)
# OCR_PREPROCESS_FAST=1 → fast unsharp-mask (~0.05s); 0 = heavy NLM+CLAHE (~2s)
OCR_PREPROCESS=1
OCR_PREPROCESS_FAST=1

# ── Quality threshold ────────────────────────────────────────────────────────
# Responses with avg OCR confidence below this are flagged as low_quality=true
OCR_MIN_CONF=45

# ── PaddleOCR CPU tuning (production x86 Linux) ──────────────────────────────
# PADDLE_ENABLE_MKLDNN=1   → Intel MKL-DNN acceleration (x86 only, auto-detected)
# PADDLE_CPU_THREADS=4     → number of inference threads (set to your core count)
# PADDLE_DET_LIMIT_SIDE_LEN=960  → cap image side for detector (lower = faster)
PADDLE_ENABLE_MKLDNN=1
PADDLE_CPU_THREADS=4
PADDLE_DET_LIMIT_SIDE_LEN=960

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WORKERS=4
CORS_ORIGINS=*
